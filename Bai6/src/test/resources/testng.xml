<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  BÀI 6: RetryListener được đăng ký ở đây → áp dụng cho mọi @Test tự động
  DEMO 1: config-dev.properties retry.count=2 → testFlakyScenario PASS (sau 2 retry)
  DEMO 2: đổi retry.count=0                  → testFlakyScenario FAIL (không retry)
-->
<suite name="Bai6-RetryAnalyzer" verbose="2">
    <!-- QUAN TRỌNG: Đăng ký RetryListener ở đây -->
    <listeners>
        <listener class-name="framework.utils.RetryListener"/>
    </listeners>
    <parameter name="browser" value="chrome"/>
    <parameter name="env"     value="dev"/>
    <test name="Flaky Simulation">
        <classes><class name="tests.Bai6_FlakySimulation"/></classes>
    </test>
</suite>
